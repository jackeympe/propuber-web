{
  "name": "propuber-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:pages": "wrangler pages dev dist --binding PROPUBER_BACKEND_URL=http://127.0.0.1:5002",
    "r2:create": "wrangler r2 bucket create propuber-assets",
    "r2:bind": "wrangler pages deploy dist",
    "be:start": "cd backend && .venv/Scripts/uvicorn.exe main:app --host 127.0.0.1 --port 5002"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "wrangler": "^4.110.0"
  }
}
